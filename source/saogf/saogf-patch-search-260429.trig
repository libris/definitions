# Seriella publikationer 

# find
saogf:Seriella%20publikationer :inCollection div:find .

# identify
saogf:Periodika :searchLabel "Tidskrifter"@sv ; # Ändra prefLabel = ändra uri
    :inCollection div:identify .

saogf:Dagstidningar :inCollection div:identify .

saogf:Monografiserier :inCollection div:identify .

saogf:Nyhetsbrev :inCollection div:identify .

saogf:%C3%85rsb%C3%B6cker :inCollection div:identify .


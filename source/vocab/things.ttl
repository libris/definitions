        ] .

:ProjectedImageInstance a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Projected Image Instance"@en, "Instans av projicerad bild"@sv;

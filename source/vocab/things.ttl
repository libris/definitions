        ] .

:TextInstance a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Text Instance"@en, "Instans av text"@sv;
    rdfs:subClassOf :Instance ;

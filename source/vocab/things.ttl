    rdfs:subClassOf :Work ;
    owl:equivalentClass dctype:Software .

# TODO: remove (incl. usages)? idea mirrored in typenormalization categories now!
:Visual a owl:Class;
    :category :pending ;
    #:category :SensoryForm ;
    ptg:abstract true ;
    rdfs:label "Visual"@en, "Visuell resurs"@sv ;
    skos:altLabel "Bild"@sv ;
    rdfs:subClassOf :Work ;
    owl:equivalentClass dctype:Image .

# Combined "Work with restricted Instance" types from MARC (000 typeOfRecord)

:ManuscriptCartography a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Manuscript Cartography"@en, "Karthandskrift"@sv;
    :inCollection marc:typeOfRecord;
    rdfs:subClassOf :Cartography ;
    rdfs:subClassOf [ a owl:Restriction;
            owl:onProperty :hasInstance;
            owl:allValuesFrom :Manuscript # Also Electronic, add genreForm Manuscript?
        ] .

:ManuscriptNotatedMusic a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Manuscript Notated Music"@en, "Musikhandskrift"@sv;
    :inCollection marc:typeOfRecord;
    rdfs:subClassOf :NotatedMusic ;
    rdfs:subClassOf [ a owl:Restriction;
            owl:onProperty :hasInstance;
            owl:allValuesFrom :Manuscript # Also Electronic, add genreForm Manuscript?
        ] .

:ManuscriptText a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Manuscript Text"@en, "Texthandskrift"@sv;
    :inCollection marc:typeOfRecord;
    rdfs:subClassOf :Text ;
    rdfs:subClassOf [ a owl:Restriction;
            owl:onProperty :hasInstance;
            owl:allValuesFrom :Manuscript # Also Electronic, add genreForm Manuscript?
        ] .


##
# Instance subclasses ("instance types")

:PhysicalResource a owl:Class ;
  rdfs:subClassOf :Instance , dc:PhysicalResource ;
  rdfs:subClassOf [ a owl:Restriction ;
          owl:onProperty :category ;
          owl:minQualifiedCardinality 1 ;
          owl:onClass [ owl:onProperty :broaderTransitive ;
                        owl:hasValue saobf:PhysicalForm ] ] ;
  rdfs:label "Fysisk resurs"@sv , "Physical resource"@en .

:DigitalResource a owl:Class ;
  rdfs:subClassOf :Instance ;
  rdfs:subClassOf [ a owl:Restriction ;
          owl:onProperty :category ;
          owl:minQualifiedCardinality 1 ;
          owl:onClass [ owl:onProperty :broaderTransitive ;
                        owl:hasValue saobf:DigitalForm ] ] ;
  rdfs:label "Digital resurs"@sv , "Digital Resource"@en .



##
# Instance subclasses (for BF2/3 compatibility)
#
# These deprecated instance classes are now entailed by categories (in turn entailed by narrower categories).
# Used for export-to-bf+rda (or revert-to-marc).
# Coordinating categories are defined in: <../categories/instanceforms.ttl> and in SAOBF

:Archival a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Arkiv"@sv;
    skos:definition "Resurser som är organiskt skapade, ackumulerade och / eller används av en person, familj eller organisation i samband med uppförande och bevaras på grund av deras fortsatta värde."@sv;
    rdfs:subClassOf :Instance;
    owl:equivalentClass bf2:Archival .

# :Electronic	9_682_076
:Electronic a owl:Class;
    :category :pending ;
    ptg:abstract true ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Elektronisk"@sv;
    skos:definition "Resurs som är avsedd för manipulering av en dator, åtkomst direkt eller på distans."@sv;
    rdfs:subClassOf :Instance;
    :inCollection marc:typeFromBib007;
    #skos:exactMatch kbrda:Computer, marc:Electronic ;
    owl:equivalentClass bf2:Electronic ;
    owl:intersectionOf (:Instance [ owl:onProperty :category ; owl:hasValue saobf:AbstractElectronic ]) .

# :Manuscript	6_734
:Manuscript a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Handskrift"@sv;
    skos:definition "Resurs som är skriven för hand eller maskinskriven. Dessa är i allmänhet unika resurser."@sv;
    rdfs:subClassOf :Instance;
    skos:narrowMatch bf2:Manuscript ; # bf2:Manuscript is a Work subclass!
    owl:equivalentClass bibo:Manuscript ;
    owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:HandmadeMaterial ]) .

# :Print	7_574_881
:Print a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    :abstract true ;
    rdfs:label "Tryck"@sv;
    skos:definition "Resurs som är mångfaldigad genom tryck."@sv;
    rdfs:subClassOf :Instance;
    owl:equivalentClass bf2:Print ;
    owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:Print]) .

# :Tactile	20_357
# TODO: cf. Instance with category ktg:Braille (design at odds with RDA Tactile Expressions...)
:Tactile a owl:Class;
    :category :pending ;
    :abstract true ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    #:category :SensoryForm ;
    rdfs:label "Taktil resurs"@sv;
    skos:altLabel "Taktilt verk"@sv;
    skos:definition "Resurs som är avsedd att uppfattas genom beröring."@sv;
    rdfs:subClassOf :Instance;
    :inCollection marc:typeFromBib007;
    owl:equivalentClass bf2:Tactile ;
    owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Tactile ] ;
    owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:Braille ]) .


# Additional Instance subclasses for MARC compatibility (mainly for MARC bib 007)

# :Microform	1_885
:Microform a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Microform"@en, "Mikroform"@sv;
    :inCollection marc:typeFromBib007;
    rdfs:subClassOf :Instance ;
    owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue kbrda:Microform ]) .


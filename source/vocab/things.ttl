# TODO: remove; never used; idea obsoleted by typenormalization
:Software a owl:Class;
    :category :pending ;
    owl:deprecated true ; # ~ <obsoleted-by-typenormalization>
    rdfs:label "Software"@en, "Programvara"@sv;
    skos:altLabel "Mjukvara"@sv;

prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>
prefix dc: <http://purl.org/dc/terms/>
prefix sdo: <https://schema.org/>
prefix ptg: <http://protege.stanford.edu/plugins/owl/protege#>

prefix bf: <http://id.loc.gov/ontologies/bibframe/>

prefix : <https://id.kb.se/vocab/>
prefix marc: <https://id.kb.se/marc/>

prefix kbrda: <https://id.kb.se/term/rda/>
prefix ktg: <https://id.kb.se/term/ktg/>
prefix saogf: <https://id.kb.se/term/saogf/>
prefix saobf: <https://id.kb.se/term/saobf/>

##
# Abstract classes entailed by categories (possibly in turn entailed).
# Used for export-to-bf+rda (or revert-to-marc).

## Work subclasses

:Audio ptg:abstract true ;
# TODO: not only :Monograph (since we don't keep these types as singularly "is" types).
#  owl:intersectionOf (:Monograph :AudioContent ) .
#:AudioContent owl:equivalentClass bf:Audio ;
#  owl:onProperty :category ; owl:hasValue ktg:Audio .
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Audio ] .

:Object ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue kbrda:ThreeDimensionalForm ] .

:Cartography ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue saogf:Kartografiskt%20material ] .

:Dataset ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Dataset ] .

:MixedMaterial ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:MixedMaterial ] .

:Kit ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Kit ] .

:Movement ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Movement ] .

:MovingImage ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:MovingImage ] .

:Multimedia ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Software ] .

:Music ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue saogf:Musik ] .

:NonMusicAudio ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Audio ] .  # saogf:Ljudb%C3%B6cker ?

:NotatedMovement ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue kbrda:NotatedMovement ] .

:NotatedMusic ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue kbrda:NotatedMusic ] .

:PerformedMusic ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue kbrda:PerformedMusic ] .

:StillImage ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue kbrda:StillImage ] .  # saogf:Bilder ?

# TODO: used; implied by ktg:Braille ?
:Tactile ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:Tactile ] .

:Text ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :category ; owl:hasValue ktg:WrittenText ] .  # saogf:Litteratur ?



## Instance subclasses

:PhysicalResource a owl:Class ;
  rdfs:subClassOf :Instance , dc:PhysicalResource ;
  rdfs:subClassOf [ a owl:Restriction ;
          owl:onProperty :category ;
          owl:minQualifiedCardinality 1 ;
          owl:onClass [ owl:onProperty :broaderTransitive ;
                        owl:hasValue saobf:PhysicalForm ] ] ;
  rdfs:label "Fysisk resurs"@sv , "Physical resource"@en .

:DigitalResource a owl:Class ;
  rdfs:subClassOf :Instance ;
  rdfs:subClassOf [ a owl:Restriction ;
          owl:onProperty :category ;
          owl:minQualifiedCardinality 1 ;
          owl:onClass [ owl:onProperty :broaderTransitive ;
                        owl:hasValue saobf:DigitalForm ] ] ;
  rdfs:label "Digital resurs"@sv , "Digital Resource"@en .


# Coordinating categories defined in: <../categories/instanceforms.ttl>

# :Instance	2_908_983 (mostly print?)

# Deprecate these Instance subclasses; and define private (blank?) mappings to just BF base classes (only for TVM)?

# We ONLY use them as internal pre-postproc classes for mapping from/to bib 007!
# TODO: ensure all of these (LHS) can be mapped to one specific type.
# Purpose here is just to define a MARC "rebus" based in on instanceOf (RHS):

# :Print	7_574_881
:Print owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:Print]) .

# :Electronic	9_682_076
:Electronic owl:intersectionOf (:Instance [ owl:onProperty :category ; owl:hasValue saobf:AbstractElectronic ]) .

# :Manuscript	6_734
:Manuscript owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:HandmadeMaterial ]) .

# :Microform	1_885
:Microform owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue kbrda:Microform ]) .

# :StillImageInstance	55_933
:StillImageInstance
  ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :instanceOf ; owl:someValuesFrom :StillImage ] .

# :Map	12_809
:Map
  ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :instanceOf ; owl:someValuesFrom :Cartography ] .

# :Globe	85
:Globe
  ptg:abstract true ;
  owl:equivalentClass [ owl:onProperty :instanceOf ; owl:someValuesFrom [ owl:onProperty :category ; owl:hasValue kbrda:CartographicThreeDimensionalForm] ] .

# :SoundRecording	172_317
:SoundRecording owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:SoundStorageMedium ]) .

# :VideoRecording	20_961
:VideoRecording owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:VideoStorageMedium ]) .

# :Tactile	20_357
:Tactile owl:intersectionOf (:PhysicalResource [ owl:onProperty :category ; owl:hasValue saobf:Braille ]) .

# - :MovingImageInstance	0!
# :MovingImageInstance :instanceOf :MovingImage .

# - :ProjectedImageInstance	0!
# :ProjectedImageInstance :instanceOf :ProjectedImage .

# :NotatedMusicInstance # ignored!
# :NotatedMusicInstance>	0!

# :KitInstance # ignored!
# KitInstance>	21

# :Archival	0


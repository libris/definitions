# Multimedia AudioBook + WrittenBook Bundle ?

#:Disc
#:CD (:Material)
#:DVD (:Material)

# Combinations:
#CDMap
#ESerial
#Music (Genre)
#MusicCD


saobf:AbstractElectronic a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  ptg:abstract true ;
  skos:closeMatch marc:Electronic ;
  #skos:narrowMatch marc:Electronic ; # ? Otherwise, ensure this match is down-prioritized
  skos:prefLabel "Elektronisk eller digital form"@sv, "Electronic or digital form"@en ;
  rdfs:comment "A digital or electronically mediated resource."@en .

# Does this have a function or does it just duplicate RDA Online Resource?
saobf:DigitalForm a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:broader saobf:AbstractElectronic ;
  skos:prefLabel "Digital form"@sv , "Digital form"@en ;
  rdfs:comment 'Kallas ibland "E-resurs"'@sv .

# Remapping broader to AbstractElectronic, so this can be combined with OnlineResource or a physical form
saobf:EBook a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:broader saobf:AbstractElectronic ;
  skos:prefLabel "E-bok"@sv, "E-book"@en.


saobf:ElectronicStorageMedium a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  ptg:abstract true ;
  skos:closeMatch kbrda:Computer ;
  skos:closeMatch marc:DirectElectronic ;
  skos:broader saobf:StorageMedium ,
      saobf:AbstractElectronic ;   # Kallas ibland "Elektronisk bärare".
  skos:prefLabel "Elektroniskt lagringsmedium"@sv , "Electronic storage medium"@en .

saobf:StandaloneDevice a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:closeMatch marc:StandaloneDevice ;
  skos:broader saobf:ElectronicStorageMedium ; # Not: PhysicalObject (that's Unmediated)
  skos:prefLabel "Fristående uppspelningsapparat"@sv , "Standalone device"@en .


# TODO: Is the media type aspect superfluous if content is on the work?
# Or is the *unit for device capable of sound* encoded here (as "mode" of provisioning, not the "purpose" thereof)?
# See also accesibility concerns.

# Will this be used in a way where it not only duplicates/mirrors RDA Audio?
saobf:SoundStorageMedium a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  ptg:abstract true ;
  #owl:sameAs kbrda:SoundRecording ; This is not an RDA type
  skos:closeMatch kbrda:Audio ;
  skos:broader saobf:StorageMedium ;
  skos:prefLabel "Lagringsmedium för ljud"@sv, "Sound storage medium"@en .

# Commented out due to comment about 0 uses (literary warrant)
# Zero uses in Libris...
#saobf:AudioWireRecording a :CarrierForm ; 
#  skos:closeMatch marc:WireRecording ;
#  skos:broader kbrda:Audio, saobf:SoundStorageMedium .

# Will this be used in a way where it not only duplicates/mirrors RDA Audio?
saobf:VideoStorageMedium a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  #owl:sameAs :VideoRecording ;
  ptg:abstract true ;
  skos:closeMatch kbrda:Video ;
  skos:relatedMatch marc:Videorecording ;
  skos:broader saobf:StorageMedium ;
  skos:prefLabel "Lagringsmedium för video"@sv, "Video storage medium"@en .

saobf:Microfilm a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:closeMatch marc:Microfilm ;
  skos:broader kbrda:Microform ;
  skos:prefLabel "Mikrofilm"@sv, "Microfilm"@en .

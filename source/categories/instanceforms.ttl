# "Mediated"

# TODO: other StorageMedium? Magnetic / Optical / Mechanical ?
# Sammanhållande toppterm
ktg:StorageMedium a :ManifestationForm ;
  ptg:abstract true ;
  skos:broader ktg:PhysicalForm ;
  skos:prefLabel "Lagringsmedium"@sv , "Storage medium"@en .


#ktg:TapeCartridge a :ManifestationForm ;

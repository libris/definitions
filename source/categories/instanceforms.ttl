saobf:ComponentPart a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:prefLabel "Bidrag"@sv, "Component part"@en .


# Cf. notation
# fmt:LargeText a :Format ?


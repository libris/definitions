prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix ptg: <http://protege.stanford.edu/plugins/owl/protege#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>

prefix : <https://id.kb.se/vocab/>

prefix marc: <https://id.kb.se/marc/>
prefix kbrda: <https://id.kb.se/term/rda/>
prefix saogf: <https://id.kb.se/term/saogf/>

prefix saobf: <https://id.kb.se/term/saobf/>

# Sammanhållande topp-term
saobf:PhysicalForm a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  ptg:abstract true ;
  skos:prefLabel "Fysisk form"@sv, "Physical form"@en .


# TODO: Printed vs. Handmade as mixins for precoordinated (7x7)?
# TODO: replace with kbrda:Printing (a :ProductionMethod ? Also defines e.g. Photocopying, but not "Manuscript/Handmade"...)
saobf:Print a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
# This MARC mapping appears to be incorrect (not Text) - should it be RegularPrint?
#  skos:closeMatch marc:Print ;
  skos:broader kbrda:Unmediated ;
  skos:prefLabel "Tryck"@sv, "Print"@en .

saobf:HandmadeMaterial a :CarrierForm ;  # NOTE: the type changed to Work in BF; this is about the carrier/production form.
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:broader kbrda:Unmediated ;
  skos:prefLabel "Handgjort material"@sv, "Handmade material"@en .


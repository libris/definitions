# "Mediated"

# TODO: other StorageMedium? Magnetic / Optical / Mechanical ?
# Sammanhållande toppterm
saobf:StorageMedium a :InstanceCategory ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  ptg:abstract true ;
  skos:broader saobf:PhysicalForm ;
  skos:prefLabel "Lagringsmedium"@sv , "Storage medium"@en .



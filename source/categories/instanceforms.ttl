# TODO: why not change most saobf:StorageMedium to saobf:ElectronicStorageMedium ?

saobf:MagneticDisk a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:closeMatch marc:MagneticDisk ;
  skos:broader saobf:ElectronicStorageMedium ;
  skos:prefLabel "Skiva för magnetisk lagring (disketter)"@sv, "Magnetic disk"@en .

# TODO: remove; zero usage?
saobf:MagnetoOpticalDisc a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:closeMatch marc:MagnetoOpticalDisc ;
  skos:broader saobf:ElectronicStorageMedium ;
  skos:prefLabel "Magnet-optisk skiva"@sv, "Magneto-optical disc"@en .

#saobf:OpticalReel a :CarrierForm ;  ptg:abstract true ;  skos:broader saobf:StorageMedium .

saobf:OpticalDisc a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:closeMatch marc:OpticalDisc ;
  skos:broader saobf:ElectronicStorageMedium ;
  skos:prefLabel "Optisk skiva (CD-A, CD-R, CD-ROM)"@sv, "Optical disc"@en .


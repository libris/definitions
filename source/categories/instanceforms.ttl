# Renamed Braille to be consistent with "Print / Volume" - can be combined with any carrier type
saobf:Braille a :CarrierForm ;
  skos:inScheme <https://id.kb.se/term/saobf> ;
  skos:closeMatch marc:Braille, marc:TextMaterialType-c, 
    marc:TacMaterialType-b ;
    skos:broader kbrda:Unmediated ;
  #skos:broader saobf:Print ; # Remove saobf:TactileForm which isn't defined
  skos:prefLabel "Punktskrift"@sv, "Braille"@en .

# exactMatch with saogf:Punktskriftsb%C3%B6cker seems dubious when one is used on the work, one on on the instance

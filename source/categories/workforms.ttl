prefix : <https://id.kb.se/vocab/>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>
prefix marcgt: <http://id.loc.gov/vocabulary/marcgt/>

prefix marc: <https://id.kb.se/marc/>
prefix saogf: <https://id.kb.se/term/saogf/>
prefix tgm: <https://id.kb.se/term/gmgpc/swe/>
prefix kbrda: <https://id.kb.se/term/rda/>
prefix div: <https://id.kb.se/term/div/>
prefix ktg: <https://id.kb.se/term/ktg/>

##
# Abstract Forms, applying to WEMI *Work*-level Works.

ktg:WrittenText a :WorkCategory ;
  :category div:abstract ;
  skos:prefLabel "Skriven text"@sv ,
    "Written Text"@en ;
  skos:related ktg:Literature ;
  skos:scopeNote "Någon form av skrift; visuell eller taktil."@sv .

ktg:Literature a :GenreForm ;
  :category div:abstract ; # may be *expressed* as written text *or* spoken form...
#  :inCollection div:find ;
  :singularLabel "Litteratur"@sv ,
    "Literature"@en ;
  skos:altLabel "Linguistic work"@en ,
    "Språkligt verk"@sv .

# See saogf:Musik which replaces this
#ktg:Music a :GenreForm ;
#  :category div:abstract ; # may be *expressed* in notation *or* preformed...
#  :inCollection div:find ;
#  skos:prefLabel "Musik"@sv , "Music"@en .

# See saogf:Kartografiskt%20material which replaces this
#ktg:Cartography a :GenreForm ;
#  :category div:abstract ;
#  :inCollection div:find ;
#  :singularLabel "Kartografiskt material"@sv,
#    "Cartographic material"@en .

ktg:Software a :GenreForm ;
  :inCollection div:find ; # TODO: demote in favour of Datorspel?
  skos:prefLabel "Mjukvara"@sv ,
    "Software"@en ;
  skos:altLabel "Datorspel, program och multimedia"@sv .

ktg:Dataset a :GenreForm ;
  #:inCollection div:find ;
  skos:prefLabel "Datamängd"@sv, "Dataset"@en .

##
# Abstract ExpressionForms for ContentTypes, applying to WEMI *Expression*-level Works.

ktg:Audio a :WorkCategory ;
  :category div:abstract ;  # div:sensoryform ;  # Hear
  skos:prefLabel "Ljud"@sv, "Audio"@en .

ktg:NonMusicAudio a :WorkCategory ;
  :category div:abstract ;
  skos:broader ktg:Audio ;
  skos:prefLabel "Ljud (ej musik)"@sv, "Non-music audio"@en ;
  skos:scopeNote "Inkluderar talat språk och naturljud."@sv .

ktg:MovingImage a :GenreForm ;
  :category div:abstract ;
  :inCollection div:find ;
  skos:broader saogf:Visuella%20verk ;
  skos:prefLabel "Rörlig bild"@sv, "Moving image"@en .

# TODO Can we use saogf:Taktila verk instead of creating this ktg term?
ktg:Tactile a :WorkCategory ;
  :category div:abstract ;
  #:inCollection div:sensoryform ;  # Feel
  skos:closeMatch saogf:Taktila%20verk ;
  skos:prefLabel "Taktil"@sv .

# See saogf:Visuella%20verk which replaces this
#ktg:VisualWork a :ExpressionForm ;
#  :category div:abstract ;  # ContentForm
#  #:inCollection div:sensoryform ;  # See
#  skos:prefLabel "Visuellt verk"@sv, "Visual work"@en .

ktg:Movement a :WorkCategory ;
  :category div:abstract ;  # ContentForm
  skos:prefLabel "Rörelser"@sv .

# Idiomatic ExpressionForms

ktg:Multimedia a :GenreForm ;
  :inCollection div:identify ;
  skos:narrowMatch marc:Combination ;  # 28501 (MTM; se identifiedBy.qualifier "talbok_text")
  skos:broader ktg:Software ;
  skos:prefLabel "Multimedia"@sv ,
    "Multimedia"@en .

ktg:MixedMaterial a :GenreForm ;
#  :inCollection div:find ;
  skos:prefLabel "Blandat material"@sv ,
    "Mixed material"@en .

ktg:Kit a :GenreForm ;
  :inCollection div:identify ;
  skos:closeMatch marc:Kit ;
  skos:broader ktg:MixedMaterial ;
  skos:prefLabel "Paket"@sv ,
    "Kit"@en .
